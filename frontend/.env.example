# LecturAI Frontend — Umgebungsvariablen
# Kopiere nach .env.local und fülle die Werte aus dem Supabase Dashboard.

# ── Supabase (öffentlich, fürs Frontend) ─────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key

# Öffentliche URL deiner Next.js-App (für Einladungs-Links in E-Mails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Server-only (NIEMALS mit NEXT_PUBLIC_ prefix, nicht ins Git!) ─────────────
# Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key

# Optional: E-Mail-Versand für Einladungen (https://resend.com)
# Ohne RESEND_API_KEY wird der Registrierungs-Link nur in der UI angezeigt.
# RESEND_API_KEY=re_...
# INVITE_FROM_EMAIL=LecturAI <noreply@deine-domain.de>
